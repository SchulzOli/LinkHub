{
  "name": "linkhub",
  "private": true,
  "version": "1.0.2",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "build:extension": "node extension/build.mjs",
    "deploy": "node extension/deploy.mjs",
    "deploy:chrome": "node extension/deploy.mjs --publish-only chrome",
    "deploy:firefox": "node extension/deploy.mjs --publish-only firefox",
    "deploy:edge": "node extension/deploy.mjs --publish-only edge",
    "deploy:dry": "node extension/deploy.mjs --dry-run"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "google-auth-library": "^10.6.2",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "web-ext-deploy": "^1.0.3"
  }
}
