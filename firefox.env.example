# Firefox Add-ons (AMO) credentials
# Obtain from: https://addons.mozilla.org/developers/addon/api/key/
JWT_ISSUER=your_jwt_issuer_here
JWT_SECRET=your_jwt_secret_here

# Extension slug on AMO (from https://addons.mozilla.org/addon/<EXT_ID>)
EXT_ID=linkhub

# Path to the extension ZIP (use {version} placeholder for auto-substitution from package.json)
ZIP=dist-extension.zip

# Optional: path to source code ZIP for AMO review
ZIP_SOURCE=linkhub-source.zip
