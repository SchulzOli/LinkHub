# Edge Add-ons Store credentials for updating an existing Partner Center product
# Setup flow:
# 1. Create the initial Edge Add-ons listing manually in Partner Center
# 2. In Partner Center, open Microsoft Edge > Publish API
# 3. Enable the Publish API experience and create API credentials
# 4. Copy the Client ID, API key, and Product ID into edge.env
# Docs:
# https://learn.microsoft.com/en-us/microsoft-edge/extensions-chromium/publish/api/using-addons-api?tabs=v1-1
# https://github.com/avi12/web-ext-deploy/blob/main/EDGE_PUBLISH_API.md

CLIENT_ID=your_client_id
API_KEY=your_api_key
PRODUCT_ID=your_product_id

# Path to the extension ZIP
ZIP=dist-extension.zip
